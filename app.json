{
  "expo": {
    "name": "Nospi",
    "slug": "nospi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/28862883-193a-4459-9ff6-e47c925d5b63.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/28862883-193a-4459-9ff6-e47c925d5b63.png",
      "resizeMode": "contain",
      "backgroundColor": "#E9D5FF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nospi.app",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Nospi necesita tu ubicación para verificar que estás en el lugar del evento y permitirte participar en la experiencia.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Nospi necesita tu ubicación para verificar que estás en el lugar del evento.",
        "NSCameraUsageDescription": "Nospi necesita acceso a tu cámara para tomar fotos de perfil.",
