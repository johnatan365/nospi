      "output": "single"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Nospi necesita acceso a tu galería para seleccionar fotos de perfil.",
          "cameraPermission": "Nospi necesita acceso a tu cámara para tomar fotos de perfil."
        }
