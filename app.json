{
  "expo": {
    "name": "Nospi",
    "slug": "nospi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/a12bc15a-afa0-463a-9d2b-980556554968.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/bf4e00c9-f687-4e0a-b462-9c0e59228257.png",
      "resizeMode": "contain",
      "backgroundColor": "#A0005A"
    },
    "ios": {
      "icon": "./assets/images/a12bc15a-afa0-463a-9d2b-980556554968.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.nospi",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Nospi necesita tu ubicaci\u00f3n para verificar que est\u00e1s en el lugar del evento y permitirte participar en la experiencia.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Nospi necesita tu ubicaci\u00f3n para verificar que est\u00e1s en el lugar del evento.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "nospi"
            ]
          }
        ]
      }
    },
    "android": {
      "icon": "./assets/images/a12bc15a-afa0-463a-9d2b-980556554968.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/0c1ed55a-9054-4f64-8e0b-fafefd7bcaf1.png",
        "backgroundColor": "#A0005A"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.nospi.jaxper",
