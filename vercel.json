{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "admin.nospi.co" }],
      "destination": "https://app.nospi.co/admin/$1",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "app.nospi.co" }],
      "destination": "/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}