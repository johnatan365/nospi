{
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "admin.nospi.co" }],
      "destination": "/admin/$1"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "app.nospi.co" }],
      "destination": "/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}